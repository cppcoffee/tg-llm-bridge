TELEGRAM_BOT_TOKEN=replace-me
# Prefer stable Telegram numeric user IDs in production. Use * only during development.
TELEGRAM_ALLOWED_USER_IDS=
DEFAULT_PROVIDER=codex

# Recommended for codex. If left empty, the bridge uses its startup directory.
WORKDIR=
# Enabled by default. Set to 0 only if codex must require a trusted Git worktree.
# CODEX_SKIP_GIT_REPO_CHECK=0

POLL_TIMEOUT_SECONDS=30
TELEGRAM_CONNECTION_POOL_SIZE=8
TELEGRAM_POOL_TIMEOUT_SECONDS=5.0
MESSAGE_MAX_CHARS=4000
SESSION_IDLE_TIMEOUT_SECONDS=2700
LOG_LEVEL=INFO
